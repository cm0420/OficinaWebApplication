# Nome da aplicação
spring.application.name=oficina

# Configuração do banco de dados
spring.datasource.url=jdbc:postgresql://localhost:5432/postgres
spring.datasource.username=postgres
spring.datasource.password=miguel04

# Configurações do JPA / Hibernate
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# Segurança
api.security.token.secret=miguel04

# Configurações de negócio
oficina.negocio.salario.atendente=1000.00
oficina.negocio.salario.mecanico=1500.00
oficina.negocio.custo.mao-de-obra=150.00
oficina.negocio.comissao.percentual=0.05
oficina.negocio.taxa-cancelamento.valor=30.00

# CORS
frontend.origin=http://localhost:5173
